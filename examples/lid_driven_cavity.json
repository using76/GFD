{
  "setup": {
    "general": {
      "name": "20x20_lid_driven_cavity",
      "dimension": 2,
      "mesh_file": "",
      "mesh_format": "generated"
    },
    "models": {
      "flow": "incompressible",
      "turbulence": "none",
      "energy": false,
      "radiation": "none",
      "solid": "none",
      "species": "none"
    },
    "materials": [
      {
        "name": "fluid",
        "material_type": "fluid",
        "properties": {
          "density": 1.0,
          "viscosity": 0.01
        }
      }
    ],
    "boundary_conditions": [
      {
        "patch": "ymax",
        "type": "wall",
        "parameters": { "vx": 1.0, "vy": 0.0, "vz": 0.0 }
      },
      {
        "patch": "ymin",
        "type": "wall",
        "parameters": {}
      },
      {
        "patch": "xmin",
        "type": "wall",
        "parameters": {}
      },
      {
        "patch": "xmax",
        "type": "wall",
        "parameters": {}
      }
    ],
    "initial_conditions": {
      "velocity": [0.0, 0.0, 0.0],
      "pressure": 0.0
    }
  },
  "solver": {
    "pv_coupling": "SIMPLE",
    "convection_scheme": "upwind",
    "relaxation": {
      "velocity": 0.5,
      "pressure": 0.3,
      "turbulence": 0.7,
      "energy": 0.9
    },
    "linear_solver": {
      "solver_type": "bicgstab",
      "max_iterations": 1000,
      "tolerance": 1e-6,
      "preconditioner": "jacobi"
    }
  },
  "run": {
    "simulation_type": "steady",
    "max_iterations": 200,
    "tolerance": 1e-4
  },
  "results": {
    "output_dir": "results",
    "format": "vtk",
    "write_interval": 50,
    "fields": ["velocity", "pressure"]
  }
}
